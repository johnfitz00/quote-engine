      "Bash(find build/reports -name \"*.xml\" 2>/dev/null | head -20)",
      "Bash(find build:*)",
      "Bash(grep -h 'testsuite\\\\|failures\\\\|errors' build/test-results/test/TEST-com.example.quoteEngine.quote.api.QuoteControllerTest*.xml | grep 'testsuite')"
